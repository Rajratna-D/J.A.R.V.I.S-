# ============================================================
# J.A.R.V.I.S. Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- News API (https://newsapi.org) ---
NEWS_API_KEY=your_newsapi_key_here

# --- Weather (https://openweathermap.org) ---
WEATHER_API_KEY=your_openweathermap_key_here
WEATHER_CITY=Mumbai                    # Default city for weather

# --- Exchange Rates (https://exchangerate-api.com) ---
EXCHANGE_API_KEY=your_exchangerate_api_key_here

# --- Ollama / Qwen ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Spotify (Optional, Phase 2) ---
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# --- User Preferences (can also be set in config/settings.yaml) ---
JARVIS_USERNAME=Sir
